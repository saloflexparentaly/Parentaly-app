# ─── ANTHROPIC (Claude / Elïa) ───────────────────────────────────────────────
# Obtenir sur https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── SUPABASE ────────────────────────────────────────────────────────────────
# Obtenir sur https://supabase.com → Projet → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # clé "service_role" (jamais exposée côté client)

# Ces deux variables sont lues par Vite (côté client) — préfixe VITE_ obligatoire
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...      # clé "anon" (publique, sans droits d'admin)

# ─── STRIPE ──────────────────────────────────────────────────────────────────
# Obtenir sur https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Price IDs — créer dans Stripe → Produits → ajouter un tarif
STRIPE_PRICE_MONTHLY=price_1TOHRf9TErY2lFQDoObZAF6t
STRIPE_PRICE_ANNUAL=price_1TOHS59TErY2lFQDZz2AterS

# Webhook secret — obtenir dans Stripe → Développeurs → Webhooks
# URL du webhook à enregistrer : https://TON-DOMAINE-RAILWAY.up.railway.app/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── SÉCURITÉ ────────────────────────────────────────────────────────────────
# Clé aléatoire pour signer les tokens premium — générer avec :
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_SECRET=une-longue-chaine-aleatoire-de-64-caracteres-hex

# ─── APP ─────────────────────────────────────────────────────────────────────
# URL publique du frontend (Railway l'assigne automatiquement)
FRONTEND_URL=https://TON-APP.up.railway.app
